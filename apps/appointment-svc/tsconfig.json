{
  "compilerOptions": {
    /* Set the source root to prevent directory nesting issues (TS5011) */
    "rootDir": "src",
    "outDir": "./dist",
    
    /* Modern Node.js standards for TypeScript 5.x+ */
    "target": "ES2020",
    "module": "Node16",
    "moduleResolution": "Node16",
    
    /* Metadata for NestJS / Dependency Injection */
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    
    /* Strictness & Interoperability */
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    
    /* Performance & Utility */
    "incremental": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "removeComments": true,
    "declaration": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "**/*.spec.ts", "**/*.test.ts"]
}